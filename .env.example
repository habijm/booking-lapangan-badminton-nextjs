# Supabase Configuration
# Get these from: Supabase Dashboard > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (for server-side admin operations ONLY)
# NEVER expose this to client-side!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# WhatsApp Number for booking (Indonesian format: 628xxx)
NEXT_PUBLIC_WHATSAPP_NUMBER=6281234567890

# Court Name
NEXT_PUBLIC_COURT_NAME=GOR Badminton Sinar Jaya

# Court Location
NEXT_PUBLIC_COURT_ADDRESS=Jl. Raya Badminton No. 1, Jakarta Selatan
